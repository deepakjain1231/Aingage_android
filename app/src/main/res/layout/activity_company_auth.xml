<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- Logo + Version row -->
    <LinearLayout
        android:id="@+id/layoutLogo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="56dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:src="@drawable/ic_app_logo"
            android:scaleType="fitCenter"
            android:contentDescription="AIngage Logo" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_marginBottom="20dp"
            android:id="@+id/tvVersion"
            android:text="V 1.0.7"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A" />

    </LinearLayout>

    <!-- Company Authentication label -->
    <TextView
        android:id="@+id/tvCompanyAuthLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="36dp"
        android:text="Company Authentication"
        android:textSize="18sp"
        android:textColor="#9E9E9E"
        app:layout_constraintTop_toBottomOf="@id/layoutLogo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Company Name input row -->
    <LinearLayout
        android:id="@+id/layoutCompanyInput"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="20dp"
        android:layout_marginStart="40dp"
        android:layout_marginEnd="40dp"
        android:paddingBottom="8dp"
        android:background="@drawable/bg_input_underline"
        app:layout_constraintTop_toBottomOf="@id/tvCompanyAuthLabel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_office"
            android:scaleType="fitCenter"
            android:contentDescription="Company"
            android:layout_marginEnd="10dp" />

        <EditText
            android:id="@+id/etCompanyName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Enter Company Name"
            android:textSize="15sp"
            android:textColor="#1A1A1A"
            android:textColorHint="#BDBDBD"
            android:inputType="textPassword"
            android:background="@null"
            android:paddingVertical="8dp" />

    </LinearLayout>

    <!-- Authenticate Button (fixed position, never moves) -->
    <Button
        android:id="@+id/btnAuthenticate"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:layout_marginTop="40dp"
        android:layout_marginStart="60dp"
        android:layout_marginEnd="60dp"
        android:text="Authenticate"
        android:textAllCaps="false"
        android:textSize="17sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:background="@drawable/bg_authenticate_button"
        android:stateListAnimator="@null"
        app:layout_constraintTop_toBottomOf="@id/layoutCompanyInput"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Full-screen centered overlay loader (floats above everything) -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:visibility="gone"
        android:indeterminateTint="@color/aingage_blue_button"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
